{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/business-backups",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/household-backups",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "src/app/api/telegram/webhook/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/help-chat/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/subscription-reminders/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/business-backups/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/household-backups/route.ts": {
      "maxDuration": 60
    }
  }
}
