# --- AI (парсинг фраз и рекомендации) ---
# Вариант A: официальный OpenAI
# OPENAI_API_KEY=sk-...

# Вариант B: xinghuapi.com (достаточно двух строк):
LLM_PROVIDER=xinghu
LLM_API_KEY=sk-...

# Или явно:
# LLM_BASE_URL=https://xinghuapi.com/v1
# LLM_MODEL=gemini-2.5-pro-all
# Модель для распознавания голоса (бот + Mini App). На прокси Whisper часто медленный:
# STT_MODEL=whisper-1
# STT_CHAT_MODEL=gemini-2.5-pro-all
# Если ответы не JSON — попробуйте LLM_JSON_FORMAT=true
# (для xinghu по умолчанию json_object выключен, достаточно промпта)

# Можно вместо LLM_* использовать те же имена:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://xinghuapi.com/v1
# OPENAI_MODEL=gemini-2.5-pro-all

NEXT_PUBLIC_TG_BOT_NAME=Fin_BU_bot

# Облако (household) — Supabase / Neon / Vercel Postgres
#
# Supabase на Vercel: используйте Transaction pooler (порт 6543), не direct :5432
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# На Vercel Preview можно дублировать: DATABASE_URL_PREVIEW=... (то же значение, только Preview)
#
# Для npm run db:push локально — Direct connection из Supabase (вкладка URI, порт 5432)
DATABASE_URL=postgresql://user:pass@host:5432/voicebudget
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Тестовый бот — только Preview на Vercel (отдельное имя, без конфликта):
# TELEGRAM_BOT_TOKEN_PREVIEW=987654321:AAF...
# NEXT_PUBLIC_TG_BOT_NAME_PREVIEW=fintest_BU_bot
# Быстрое распознавание голоса в боте (бесплатный tier): https://console.groq.com → API Keys
# --- Голос в Telegram-боте (отдельно от xinghu для текста!) ---
# Вариант A — Groq (быстро, бесплатный tier): https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_API_KEY_PREVIEW=gsk_...   # только Preview на Vercel (тестовый бот)
#
# Вариант B — apinet.cloud только для Whisper:
# STT_API_KEY=sk-...          # ключ из apinet → Ключи
# STT_BASE_URL=https://apinet.cloud/v1
# STT_MODEL=whisper-1
# Секрет для POST /api/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=random-secret-string
HOUSEHOLD_SESSION_SECRET=change-me-to-random-64-chars
RESEND_API_KEY=re_...
AUTH_EMAIL_FROM=FIN OS <login@auth.example.com>
EMAIL_PROVIDER=gmail_smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=app-password
# Включение email cloud login / multi-device sync UI
# NEXT_PUBLIC_CLOUD_SYNC_ENABLED=true

# Участники облака → Google Таблица (см. docs/GOOGLE-SHEETS.md)
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# TELEGRAM_ADMIN_CHAT_ID=123456789   # заявки из «Страхование и услуги» → личка
# NEXT_PUBLIC_FORTUNE_WHEEL_URL=https://t.me/Fortuna_Fin_Bot
# NEXT_PUBLIC_OSAGO_FORM_URL=https://forms.yandex.ru/...   # опционально, вторая кнопка на ОСАГО
# NEXT_PUBLIC_SITE_URL=https://voicebudget.vercel.app
# Preview (тест-бот @fintest_BU_bot) — только Environment Preview на Vercel:
# NEXT_PUBLIC_SITE_URL_PREVIEW=https://voicebudget-xxxx.vercel.app
# Нижние вкладки Семья / Бизнес / Ещё (по умолчанию включены; выключить: false)
# NEXT_PUBLIC_APP_BOTTOM_NAV=false
# Trial-плашка только при SUBSCRIPTION_BILLING_TEST=true (не на проде до ЮKassa):
# SUBSCRIPTION_BILLING_TEST=true
# NEXT_PUBLIC_DIAGNOSTICS_FORM_URL=https://forms.yandex.ru/...
# DIAGNOSTICS_FORM_URL=https://forms.yandex.ru/...   # сервер (работает без пересборки NEXT_PUBLIC)
# Уроки: в приложении уже встроен каталог ВЕД. Env переопределяет список (строгий JSON-массив):
# EDUCATION_VIDEOS_JSON=[{"title":"Урок 1","url":"https://youtu.be/..."},{"title":"Урок 2","url":"https://..."}]
# Битый формат без [] тоже парсится; лучше один массив в одну строку.
# Тест trial без initData (только Preview + SUBSCRIPTION_BILLING_TEST):
# BILLING_DEV_TELEGRAM_ID=123456789
# NEXT_PUBLIC_BILLING_DEV_TELEGRAM_ID=123456789

# AI-рекомендации: ваше имя и контакт для CTA в последнем совете
ADVISOR_NAME=финансовый советник
ADVISOR_NAME_DATIVE=финансовому советнику
ADVISOR_NAME_INSTRUMENTAL=финансовым советником
ADVISOR_CONTACT=Telegram: @fin_108
# Дублируйте для клиента (опционально):
# NEXT_PUBLIC_ADVISOR_NAME=финансовый советник
# NEXT_PUBLIC_ADVISOR_NAME_DATIVE=финансовому советнику
# NEXT_PUBLIC_ADVISOR_NAME_INSTRUMENTAL=финансовым советником
# NEXT_PUBLIC_ADVISOR_CONTACT=Telegram: @fin_108

# Тест AI без ожидания 30 дней (только dev):
# NEXT_PUBLIC_AI_RECOMMENDATIONS_MIN_DAYS=1

# --- ЮKassa (подписка на облако + бот) ---
# Тест биллинга без ЮKassa: trial + paywall + плашка сверху
# SUBSCRIPTION_BILLING_TEST=true
# SUBSCRIPTION_TRIAL_DAYS=31
# Рефералы: бонусные дни (по умолчанию 14+14). Отключить: REFERRAL_DISABLED=true
# REFERRAL_BONUS_DAYS_REFERRER=14
# REFERRAL_BONUS_DAYS_REFERRED=14
# REFERRAL_BONUS_DAYS_REFERRER_PREVIEW=14
# REFERRAL_BONUS_DAYS_REFERRED_PREVIEW=14
# Тестовые ключи: личный кабинет ЮKassa → Настройки → shopId + secret_key
# YOOKASSA_SHOP_ID=123456
# YOOKASSA_SECRET_KEY=test_...
# YOOKASSA_SUBSCRIPTION_AMOUNT=299
# YOOKASSA_SUBSCRIPTION_DAYS=30
# Пробный период для новых пользователей (дни, суммируется с промокодом): SUBSCRIPTION_TRIAL_DAYS=14
# Отключить paywall (dev): YOOKASSA_SUBSCRIPTION_DISABLED=true
# Бесплатно для всех до даты (ISO), даже с ключами ЮKassa: SUBSCRIPTION_FREE_UNTIL=2026-08-01
# Webhook URL в ЮKassa: https://YOUR_DOMAIN/api/payments/yookassa/webhook
